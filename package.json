{
  "name": "payroll-server",
  "version": "1.0.0",
  "description": "Payroll & Expense Management System - Backend API",
  "main": "dist/server.js",
  "scripts": {
    "dev": "nodemon --exec ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "seed:dev": "ts-node src/scripts/seed-dev.ts",
    "seed:rbac": "ts-node src/scripts/seedRolesAndPermissions.ts",
    "migrate:up": "ts-node src/migrations/run.ts up",
    "migrate:down": "ts-node src/migrations/run.ts down",
    "db:reset": "ts-node src/scripts/dbReset.ts",
    "seed:all": "ts-node src/scripts/seedAll.ts",
    "seed:fixtures:dev": "cross-env NODE_ENV=development ts-node src/scripts/seed-fixtures.ts",
    "db:reset:test": "cross-env NODE_ENV=test ts-node src/scripts/dbReset.ts",
    "seed:fixtures:test": "cross-env NODE_ENV=test ts-node src/scripts/seed-fixtures.ts",
    "test:flows": "cross-env NODE_ENV=test vitest run"
  },
  "keywords": [
    "payroll",
    "expense-management",
    "kenya"
  ],
  "author": "Innovasure",
  "license": "MIT",
  "dependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.0",
    "@types/pdfkit": "^0.17.4",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.15.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "handlebars": "^4.7.8",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.2",
    "nodemailer": "^6.9.7",
    "pdfkit": "^0.17.2",
    "pg": "^8.11.3",
    "pg-hstore": "^2.3.4",
    "puppeteer": "^24.40.0",
    "sequelize": "^6.35.2",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.18.3"
  },
  "devDependencies": {
    "@types/nodemailer": "^6.4.14",
    "@types/pg": "^8.11.10",
    "@types/puppeteer": "^5.4.7",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.17.0",
    "@typescript-eslint/parser": "^6.17.0",
    "@vitest/ui": "^2.1.4",
    "cross-env": "^10.1.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.1.2",
    "nodemon": "^3.0.2",
    "prettier": "^3.4.2",
    "supertest": "^7.1.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
